572. SGa and pga of pdb || pdb sga || pdb pga 
set lines 300 pages 1000
col pdb_name for a20
col ""'pga_aggregate_target'"" for 99999
col ""'sga_max_size'"" for 99999
col ""'sga_target'"" for 99999
col ""'pga_aggregate_limit'"" for 9999
COLUMN flag NOPRINT;
COMPUTE SUM OF ""'sga_max_size'"" ON flag;
COMPUTE SUM OF ""'pga_aggregate_target'"" ON flag
COMPUTE SUM OF ""'sga_target'"" ON flag
COMPUTE SUM OF ""'pga_aggregate_limit'"" ON flag
BREAK ON flag SKIP 1;
SELECT case when mem.pdb_name='ROOT' then 'root' else 'pdb' end as flag ,mem.*
  FROM (
select nvl(b.name,'ROOT') pdb_name, a.name , nvl(value/1024/1024/1024,0) size_gb from v$system_parameter a,v$pdbs b where a.con_id=b.con_id(+) and a.name in ('sga_max_size','sga_target','pga_aggregate_limit','pga_aggregate_target'))
PIVOT (
  MAX(size_gb) FOR name IN ('sga_max_size','sga_target','pga_aggregate_limit','pga_aggregate_target')
) mem where mem.pdb_name  not like '%SEED%' order by 1; 

