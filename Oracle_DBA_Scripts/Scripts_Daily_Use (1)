                     ,SUM (sql.BUFFER_GETS_DELTA) BUFFER_GETS
                     ,SUM (sql.disk_reads_delta) disk_reads
                     ,ROUND (SUM (sql.cpu_time_delta / 1000000)) cpu_sec
                     ,SUM (sql.SORTS_DELTA) SORTS
                     ,SUM (sql.LOADS_DELTA) LOADS
