 select * 
from (select sql.SQL_ID
                     ,PARSING_SCHEMA_NAME
                     ,DBMS_LOB.SUBSTR(SQL_TEXT,250) SQLTEXT
                     ,SUM (sql.executions_delta) execs
                     ,ROUND (SUM (sql.elapsed_time_delta / 1000000)) elapsed_sec
