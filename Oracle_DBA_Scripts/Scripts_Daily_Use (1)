                     ,SUM (sql.PARSE_CALLS_DELTA) PARSE_CALLS
                     ,to_char(SUM (sql.CPU_TIME_DELTA)) CPU_TIME
                     ,to_char(SUM (sql.iowait_delta)) iowait
                     ,SUM (sql.APWAIT_DELTA) APWAIT
                     ,SUM (sql.CCWAIT_DELTA) CCWAIT
